            "environment": [],
            "externalConsole": false,
            "MIMode": "lldb",
            "miDebuggerPath": "/usr/bin/lldb",
            "preLaunchTask": "CMake: Build Debug",
            "internalConsoleOptions": "neverOpen"
        },
        {
